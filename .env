# Database
DATABASE_URL=sqlite:///./modakbul.db

# Server
PORT=8000

# Security
SECRET_KEY=your-secret-key-replace-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Burn Rate
BASE_MINUTES=10.0
DECAY_RATE=0.90
MAX_LIFESPAN_HOURS=24

# DB Schema Limits
USERNAME_LENGTH_MAX=31
NICKNAME_LENGTH_MAX=31
TOPIC_LENGTH_MAX=127
COMMENT_LENGTH_MAX=1023